APP_URL=http://localhost:8080/
CONTACT_TO=info@dreambouwgroup.com

# Docker local uses the db service. In hosting, use the values from your panel.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=dreambouw
DB_USERNAME=dreambouw
DB_PASSWORD=dreambouw
DB_CHARSET=utf8mb4

# SQLite fallback if you set DB_CONNECTION=sqlite.
# DATABASE_PATH=/var/www/html/storage/database.sqlite

# Generate with:
# docker compose run --rm web php scripts/create-admin-hash.php "your-secure-password"
ADMIN_PASSWORD_HASH=''
